# Copy to .env — never commit .env.

# Neon / Postgres (if pg errors on channel_binding, drop &channel_binding=require)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

JWT_SECRET=change-me-to-a-long-random-string

# Primary frontend URL (must match the site that calls this API in production)
FRONTEND_URL=http://localhost:3000

# Optional: extra allowed origins for CORS (comma-separated), e.g. Vercel + local:
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Optional: comma-separated emails allowed to register as business (owner)
OWNER_EMAILS=you@example.com

PORT=4000
